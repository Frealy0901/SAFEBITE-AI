Imports System.IO

Public Class Form3

    Dim ruleFile As String = "rule.txt"

    Dim gambar1 As String = ""
    Dim gambar2 As String = ""

    ' BROWSE GAMBAR 1
    Private Sub Button1_Click(sender As Object, e As EventArgs) Handles Button1.Click

        Using dlg As New OpenFileDialog

            dlg.Filter = "Image|*.png;*.jpg"

            If dlg.ShowDialog = DialogResult.OK Then

                gambar1 = dlg.FileName

                PictureBox1.Image =
                    Image.FromFile(gambar1)

            End If

        End Using

    End Sub


    ' BROWSE GAMBAR 2
    Private Sub Button2_Click(sender As Object, e As EventArgs) Handles Button2.Click

        Using dlg As New OpenFileDialog

            dlg.Filter = "Image|*.png;*.jpg"

            If dlg.ShowDialog = DialogResult.OK Then

                gambar2 = dlg.FileName

                PictureBox2.Image =
                    Image.FromFile(gambar2)

            End If

        End Using

    End Sub


    ' SIMPAN RULE
    Private Sub Button3_Click(sender As Object, e As EventArgs) Handles Button3.Click

        If ComboBox1.Text = "" Or ComboBox2.Text = "" Then

            MessageBox.Show("Isi item dulu")
            Exit Sub

        End If

        Dim rule As String =
            ComboBox1.Text &
            "," &
            ComboBox2.Text

        File.AppendAllText(
            ruleFile,
            Environment.NewLine & rule
        )

        MessageBox.Show("Rule ditambahkan")

        Me.Close()

    End Sub

End Class



